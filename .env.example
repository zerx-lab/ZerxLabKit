# 应用运行环境：dev（开发）| prod（生产）
APP_ENV=dev

# HTTP 服务监听地址
SERVER_ADDR=:8080

# 数据库驱动，取值之一：sqlite | postgres | mysql。
# 开发环境用 PostgreSQL，由 `task sync`（或 `task db:up`）自动启动。
DB_DRIVER=postgres
DB_DSN=host=localhost user=zerx password=zerx dbname=zerxlab port=5432 sslmode=disable
# 零依赖替代方案（无需 Docker）——基于文件的 SQLite：
# DB_DRIVER=sqlite
# DB_DSN=file:zerxlab.db?_journal_mode=WAL&_busy_timeout=5000&mode=rwc

# JWT 签名密钥（必填）。生产环境务必修改为强随机值，缺失会导致启动失败。
JWT_SECRET=dev-insecure-change-me
# 访问令牌（access token）有效期
JWT_ACCESS_TTL=15m
# 刷新令牌（refresh token）有效期，默认 7 天（168 小时）
JWT_REFRESH_TTL=168h

# 无默认账号。首次运行时在 /register 注册第一个用户，该用户自动成为管理员。

# 认证安全加固。
# AUTH_SINGLE_SESSION=true 强制单设备登录（每次登录会踢掉该用户的其他会话）。
# 默认 false 允许多端并发登录，可在「会话管理」页面统一管理。
AUTH_SINGLE_SESSION=false
# 登录失败计数（按 邮箱+IP，滑动窗口长度 = AUTH_LOCK_FOR）：
# 达到 AUTH_CAPTCHA_THRESHOLD 次后要求输入验证码，
# 达到 AUTH_LOCK_THRESHOLD 次后临时锁定账号。
AUTH_CAPTCHA_THRESHOLD=2
AUTH_LOCK_THRESHOLD=5
# 锁定时长 / 滑动窗口长度
AUTH_LOCK_FOR=15m

# 文件上传的对象存储。驱动取值之一：local | s3。
STORAGE_DRIVER=local
# local 驱动：文件写入 STORAGE_LOCAL_DIR 目录，并通过 STORAGE_LOCAL_BASE_URL 对外访问。
STORAGE_LOCAL_DIR=./data/uploads
STORAGE_LOCAL_BASE_URL=/uploads
# s3 驱动（兼容 S3，例如 MinIO）。当 STORAGE_DRIVER=s3 时取消注释并填写。
# STORAGE_S3_ENDPOINT=localhost:9000
# STORAGE_S3_ACCESS_KEY=minioadmin
# STORAGE_S3_SECRET_KEY=minioadmin
# STORAGE_S3_BUCKET=zerxlab
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_SECURE=false
# 对象的公开访问根地址；留空则返回预签名 GET 链接（有效期 7 天）。
# STORAGE_S3_PUBLIC_URL=http://localhost:9000/zerxlab

# 密码策略。调整密码强度要求与历史复用限制。
# 最小长度
PASSWORD_MIN_LENGTH=8
# 是否必须包含大写字母
PASSWORD_REQUIRE_UPPER=false
# 是否必须包含小写字母
PASSWORD_REQUIRE_LOWER=false
# 是否必须包含数字
PASSWORD_REQUIRE_DIGIT=true
# 是否必须包含特殊符号
PASSWORD_REQUIRE_SYMBOL=false
# 禁止复用最近 N 个旧密码（0 表示关闭历史校验）。
PASSWORD_HISTORY_COUNT=3

# 出站邮件（SMTP），用于密码重置。
# 当 SMTP_ENABLED=false 时，重置链接不会真正发送，而是写入服务端日志（方便开发调试）。
SMTP_ENABLED=false
# SMTP 服务器地址
SMTP_HOST=
# SMTP 端口（587 = STARTTLS，465 = SSL/TLS）
SMTP_PORT=587
# SMTP 认证用户名
SMTP_USERNAME=
# SMTP 认证密码
SMTP_PASSWORD=
# 发件人邮箱地址
SMTP_FROM_ADDR=
# 发件人显示名称
SMTP_FROM_NAME=zerxLabKit

# 全局按 IP 限流（令牌桶算法），保护包括登录在内的所有 RPC 接口。
RATE_LIMIT_ENABLED=true
# 每个 IP 每秒允许的请求数（令牌补充速率）
RATE_LIMIT_RPS=20
# 突发请求上限（令牌桶容量）
RATE_LIMIT_BURST=40
# 空闲 IP 条目的存活时间，超时后清理以释放内存
RATE_LIMIT_TTL=10m

# API 文档。为 true 时公开提供 /api/docs（Scalar UI）与 /api/openapi.yaml。
# 生产环境建议设为 false 以隐藏接口规格。
DOCS_ENABLED=true
