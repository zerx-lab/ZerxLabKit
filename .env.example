# Application environment: dev | prod
APP_ENV=dev

# HTTP server listen address
SERVER_ADDR=:8080

# Database: driver is one of sqlite | postgres | mysql.
# Dev uses PostgreSQL, auto-started by `task sync` (or `task db:up`).
DB_DRIVER=postgres
DB_DSN=host=localhost user=zerx password=zerx dbname=zerxlab port=5432 sslmode=disable
# Zero-dependency alternative (no Docker) — file-based SQLite:
# DB_DRIVER=sqlite
# DB_DSN=file:zerxlab.db?_journal_mode=WAL&_busy_timeout=5000&mode=rwc

# JWT signing (REQUIRED). Change this in production.
JWT_SECRET=dev-insecure-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# No default credentials. On first run, register the first user at /register —
# it automatically becomes the admin.

# Authentication hardening.
# AUTH_SINGLE_SESSION=true forces single-device login (each login evicts the
# user's other sessions). Default false allows multiple concurrent sessions,
# managed from the Sessions page.
AUTH_SINGLE_SESSION=false
# Failed-login attempts (per email+IP, sliding window = AUTH_LOCK_FOR) before a
# captcha is required, then before the account is temporarily locked.
AUTH_CAPTCHA_THRESHOLD=2
AUTH_LOCK_THRESHOLD=5
AUTH_LOCK_FOR=15m

# Object storage for file uploads. Driver is one of local | s3.
STORAGE_DRIVER=local
# local driver: files are written under STORAGE_LOCAL_DIR and served at
# STORAGE_LOCAL_BASE_URL.
STORAGE_LOCAL_DIR=./data/uploads
STORAGE_LOCAL_BASE_URL=/uploads
# s3 driver (S3-compatible, e.g. MinIO). Uncomment and set when STORAGE_DRIVER=s3.
# STORAGE_S3_ENDPOINT=localhost:9000
# STORAGE_S3_ACCESS_KEY=minioadmin
# STORAGE_S3_SECRET_KEY=minioadmin
# STORAGE_S3_BUCKET=zerxlab
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_SECURE=false
# Public base URL for objects; if empty, presigned GET URLs (7d) are returned.
# STORAGE_S3_PUBLIC_URL=http://localhost:9000/zerxlab
