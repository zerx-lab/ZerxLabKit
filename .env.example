# Application environment: dev | prod
APP_ENV=dev

# HTTP server listen address
SERVER_ADDR=:8080

# Database: driver is one of sqlite | postgres | mysql
DB_DRIVER=sqlite
DB_DSN=file:zerxlab.db?_journal_mode=WAL&_busy_timeout=5000&mode=rwc

# JWT signing (REQUIRED). Change this in production.
JWT_SECRET=dev-insecure-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# No default credentials. On first run, register the first user at /register —
# it automatically becomes the admin.
